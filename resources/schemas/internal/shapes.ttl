##     sh:targetClass ontolex:LexicalSense ;
##     sh:property [
##         sh:path ontolex:isLexicalizedSenseOf ;
##         sh:minCount 1 ; sh:maxCount 1 ;
##         sh:class ontolex:LexicalConcept ;
##         sh:message "A sense must lexicalize exactly one synset." ] .
