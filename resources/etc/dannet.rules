#------------------------------------------------------------------
# DanNet inference rules for Jena's GenericRuleReasoner (HYBRID mode).
#
# This is a purpose-built replacement for the hacked-down copy of
# Jena's OWL micro/FB rule set previously found in this file.
# DanNet's schemas only exercise two kinds of OWL/RDFS inference:
#
#   1. owl:inverseOf      - nearly every wn:/dns: synset relation
#      declares an inverse; symmetric relations (e.g. wn:antonym,
#      dns:nearAntonym) are modeled as self-inverses.
#   2. rdfs:subPropertyOf - SKOS mappings declared on wn:/dns:
#      properties, e.g. wn:hypernym -> skos:broader and
#      dns:eqHypernym -> skos:broadMatch.
#
# Both are implemented as forward rules generating *tabled backward*
# rules per property (pair), so the derived triples are computed on
# demand at query time rather than being materialized in the store.
#
# Deliberately omitted (inferring nothing or too costly for our data):
#   - equality reasoning (owl:sameAs, Functional/InverseFunctional)
#   - OWL restrictions, cardinality, disjointness, validation rules
#   - domain/range type entailment (rdfs2/rdfs3); all rdf:type
#     assertions in DanNet are explicit
#   - transitive property closure; use SPARQL property paths instead,
#     e.g. `wn:hypernym+` or `skos:broader+`
#------------------------------------------------------------------

#------------------------------------------------------------------
# Tabling directives
#------------------------------------------------------------------

-> table(rdf:type).
-> table(rdfs:subClassOf).
-> table(rdfs:range).
-> table(rdfs:domain).

#------------------------------------------------------------------
# owl:inverseOf
#------------------------------------------------------------------

[inverseOf1: (?P owl:inverseOf ?Q) -> (?Q owl:inverseOf ?P) ]

[inverseOf2: (?P owl:inverseOf ?Q) -> table(?P), table(?Q),
             [inverseOf2b: (?X ?P ?Y) <- (?Y ?Q ?X)] ]

# Propagate domain/range declarations across inverse pairs.
[inverseOf5: (?P owl:inverseOf ?Q), (?P rdfs:range ?C) -> (?Q rdfs:domain ?C) ]
[inverseOf6: (?P owl:inverseOf ?Q), (?P rdfs:domain ?C) -> (?Q rdfs:range ?C) ]

#------------------------------------------------------------------
# rdfs:subPropertyOf
#------------------------------------------------------------------

# Transitivity of subPropertyOf itself (rdfs5); cheap on schema-sized data.
[rdfs5: (?P rdfs:subPropertyOf ?Q), (?Q rdfs:subPropertyOf ?R), notEqual(?P, ?R)
        -> (?P rdfs:subPropertyOf ?R) ]

# Property assertions entail assertions of their superproperties (rdfs6),
# e.g. (?A wn:hypernym ?B) entails (?A skos:broader ?B).
[rdfs6: (?P rdfs:subPropertyOf ?Q), notEqual(?P, ?Q) -> table(?P), table(?Q),
        [rdfs6b: (?A ?Q ?B) <- (?A ?P ?B)] ]
